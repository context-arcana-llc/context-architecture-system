#!/usr/bin/env bash
# Pre-commit secret scanner for CAS repositories.
# Blocks commits that contain likely secrets or PII.
# Install: from repo root, run  `git config core.hooksPath .githooks`
# macOS / Linux: also run  `chmod +x .githooks/pre-commit .githooks/pre-push`

set -u

RED=$'\033[0;31m'
YEL=$'\033[1;33m'
GRN=$'\033[0;32m'
NC=$'\033[0m'

# Staged files (added/copied/modified), excluding deletions.
# mapfile requires bash 4.0+; macOS ships bash 3.2, so use a while-loop instead.
FILES=()
while IFS= read -r f; do FILES+=("$f"); done \
  < <(git diff --cached --name-only --diff-filter=ACM | tr -d '\r')

if [ ${#FILES[@]} -eq 0 ]; then
  exit 0
fi

# Patterns: label|regex
# Tuned to favor specificity over recall to limit false positives on a content repo.
PATTERNS=(
  "AWS Access Key ID|AKIA[0-9A-Z]{16}"
  "AWS Secret Access Key|aws(.{0,20})?(secret|sk)[^a-z0-9]{0,5}[A-Za-z0-9/+=]{40}"
  "Google API Key|AIza[0-9A-Za-z_\\-]{35}"
  "Stripe Live Key|sk_live_[0-9a-zA-Z]{24,}"
  "Stripe Restricted Key|rk_live_[0-9a-zA-Z]{24,}"
  "GitHub Token|gh[pousr]_[A-Za-z0-9_]{36,}"
  "Slack Token|xox[abprs]-[A-Za-z0-9-]{10,}"
  "Private Key Block|-----BEGIN (RSA|DSA|EC|OPENSSH|PGP|ENCRYPTED) PRIVATE KEY-----"
  "JWT Token|eyJ[A-Za-z0-9_-]{10,}\\.eyJ[A-Za-z0-9_-]{10,}\\.[A-Za-z0-9_-]{10,}"
  "Generic Secret Assignment|(password|passwd|pwd|secret|api[_-]?key|access[_-]?token|auth[_-]?token)[[:space:]]*[:=][[:space:]]*[\"'][^\"']{6,}[\"']"
  "Social Security Number|(^|[^0-9])[0-9]{3}-[0-9]{2}-[0-9]{4}([^0-9]|$)"
  "Credit Card (Visa/MC/Amex/Disc)|(^|[^0-9])(4[0-9]{12}(?:[0-9]{3})?|5[1-5][0-9]{14}|3[47][0-9]{13}|6(?:011|5[0-9]{2})[0-9]{12})([^0-9]|$)"
  "Driver License Label|(driver[\\s_-]?license|DL[\\s#:]+[A-Z0-9]{6,})"
  "Bank Routing/Account Label|(routing[\\s_-]?(number|#)|account[\\s_-]?(number|#))[\\s:=]+[0-9]{6,}"
  "IBAN|\\b[A-Z]{2}[0-9]{2}[A-Z0-9]{11,30}\\b"
)

FAIL=0
REPORT=""

is_binary() {
  # $'\x00' expands to an empty string in bash (NUL bytes can't live in
  # bash strings), so the previous check matched every non-empty file and
  # silently skipped all text. Use grep -I's built-in binary detection.
  ! LC_ALL=C grep -Iq '' "$1" 2>/dev/null
}

for f in "${FILES[@]}"; do
  case "$f" in
    .githooks/pre-commit|.githooks/pre-push) continue ;;
    *.png|*.jpg|*.jpeg|*.gif|*.webp|*.pdf|*.zip|*.gz|*.tgz|*.7z|*.mp4|*.mov|*.mp3|*.wav|*.ico|*.psd|*.ai|*.sketch|*.fig) continue ;;
  esac
  [ -f "$f" ] || continue
  is_binary "$f" && continue

  for entry in "${PATTERNS[@]}"; do
    label="${entry%%|*}"
    regex="${entry#*|}"
    if hits=$(grep -n -I -P -- "$regex" "$f" 2>/dev/null); then
      :
    else
      hits=$(grep -n -I -E -i -- "$regex" "$f" 2>/dev/null || true)
    fi
    if [ -n "$hits" ]; then
      FAIL=1
      REPORT+="${RED}[${label}]${NC} $f"$'\n'
      while IFS= read -r line; do
        REPORT+="    ${line:0:200}"$'\n'
      done < <(printf '%s\n' "$hits" | head -n 3)
    fi
  done
done

if [ "$FAIL" -ne 0 ]; then
  printf '%s\n' "${RED}Pre-commit blocked: potential secret/PII detected.${NC}"
  printf '%s' "$REPORT"
  printf '\n%s\n' "${YEL}If this is a false positive, bypass with:  git commit --no-verify${NC}"
  printf '%s\n' "${YEL}(Only do this if you have visually confirmed the content is safe.)${NC}"
  exit 1
fi

printf '%s\n' "${GRN}pre-commit: no secrets detected in staged content.${NC}"
exit 0
