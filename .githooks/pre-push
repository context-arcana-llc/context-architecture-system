#!/usr/bin/env bash
# Pre-push secret scanner for CAS repositories.
# Re-scans the full set of commits being pushed — catches anything that slipped
# past pre-commit (e.g., --no-verify or commits made before the hook was installed).
# Install: from repo root, run  `git config core.hooksPath .githooks`
# macOS / Linux: also run  `chmod +x .githooks/pre-commit .githooks/pre-push`

set -u

RED=$'\033[0;31m'
YEL=$'\033[1;33m'
GRN=$'\033[0;32m'
NC=$'\033[0m'

ZERO="0000000000000000000000000000000000000000"

PATTERNS=(
  "AWS Access Key ID|AKIA[0-9A-Z]{16}"
  "AWS Secret Access Key|aws(.{0,20})?(secret|sk)[^a-z0-9]{0,5}[A-Za-z0-9/+=]{40}"
  "Google API Key|AIza[0-9A-Za-z_\\-]{35}"
  "Stripe Live Key|sk_live_[0-9a-zA-Z]{24,}"
  "Stripe Restricted Key|rk_live_[0-9a-zA-Z]{24,}"
  "GitHub Token|gh[pousr]_[A-Za-z0-9_]{36,}"
  "Slack Token|xox[abprs]-[A-Za-z0-9-]{10,}"
  "Private Key Block|-----BEGIN (RSA|DSA|EC|OPENSSH|PGP|ENCRYPTED) PRIVATE KEY-----"
  "JWT Token|eyJ[A-Za-z0-9_-]{10,}\\.eyJ[A-Za-z0-9_-]{10,}\\.[A-Za-z0-9_-]{10,}"
  "Generic Secret Assignment|(password|passwd|pwd|secret|api[_-]?key|access[_-]?token|auth[_-]?token)[[:space:]]*[:=][[:space:]]*[\"'][^\"']{6,}[\"']"
  "Social Security Number|(^|[^0-9])[0-9]{3}-[0-9]{2}-[0-9]{4}([^0-9]|$)"
  "Credit Card (Visa/MC/Amex/Disc)|(^|[^0-9])(4[0-9]{12}(?:[0-9]{3})?|5[1-5][0-9]{14}|3[47][0-9]{13}|6(?:011|5[0-9]{2})[0-9]{12})([^0-9]|$)"
  "Driver License Label|(driver[\\s_-]?license|DL[\\s#:]+[A-Z0-9]{6,})"
  "Bank Routing/Account Label|(routing[\\s_-]?(number|#)|account[\\s_-]?(number|#))[\\s:=]+[0-9]{6,}"
  "IBAN|\\b[A-Z]{2}[0-9]{2}[A-Z0-9]{11,30}\\b"
)

FAIL=0
REPORT=""

scan_range() {
  local range="$1"
  # mapfile requires bash 4.0+; macOS ships bash 3.2, so use a while-loop instead.
  local files=()
  while IFS= read -r f; do files+=("$f"); done \
    < <(git diff --name-only --diff-filter=ACMR "$range" 2>/dev/null)
  for f in "${files[@]}"; do
    [ -n "$f" ] || continue
    case "$f" in
      .githooks/pre-commit|.githooks/pre-push) continue ;;
      *.png|*.jpg|*.jpeg|*.gif|*.webp|*.pdf|*.zip|*.gz|*.tgz|*.7z|*.mp4|*.mov|*.mp3|*.wav|*.ico|*.psd|*.ai|*.sketch|*.fig) continue ;;
    esac
    local content
    content=$(git show "${range##*..}:$f" 2>/dev/null) || continue
    [ -n "$content" ] || continue
    for entry in "${PATTERNS[@]}"; do
      local label="${entry%%|*}"
      local regex="${entry#*|}"
      local hits
      if hits=$(printf '%s' "$content" | grep -n -I -P -- "$regex" 2>/dev/null); then
        :
      else
        hits=$(printf '%s' "$content" | grep -n -I -E -i -- "$regex" 2>/dev/null || true)
      fi
      if [ -n "$hits" ]; then
        FAIL=1
        REPORT+="${RED}[${label}]${NC} $f"$'\n'
        while IFS= read -r line; do
          REPORT+="    ${line:0:200}"$'\n'
        done < <(printf '%s\n' "$hits" | head -n 3)
      fi
    done
  done
}

while read -r local_ref local_sha remote_ref remote_sha; do
  [ -n "$local_sha" ] || continue
  if [ "$local_sha" = "$ZERO" ]; then
    continue
  fi
  if [ "$remote_sha" = "$ZERO" ]; then
    range=$(git rev-list "$local_sha" --not --remotes 2>/dev/null | tail -n 1)
    if [ -n "$range" ]; then
      scan_range "${range}^..${local_sha}"
    else
      scan_range "$local_sha~1..$local_sha"
    fi
  else
    scan_range "${remote_sha}..${local_sha}"
  fi
done

if [ "$FAIL" -ne 0 ]; then
  printf '%s\n' "${RED}Pre-push blocked: potential secret/PII detected in commits being pushed.${NC}"
  printf '%s' "$REPORT"
  printf '\n%s\n' "${YEL}Remove the offending content (and rewrite history if already committed), then push again.${NC}"
  printf '%s\n' "${YEL}Force-bypass:  git push --no-verify  (use only after visual confirmation).${NC}"
  exit 1
fi

printf '%s\n' "${GRN}pre-push: no secrets detected.${NC}"
exit 0
